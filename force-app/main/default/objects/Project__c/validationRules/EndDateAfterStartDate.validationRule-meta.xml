<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>EndDateAfterStartDate</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(ISBLANK(EndDate__c)) &amp;&amp; EndDate__c &lt;= StartDate__c</errorConditionFormula>
    <errorDisplayField>EndDate__c</errorDisplayField>
    <errorMessage>End Date must be after Start Date.</errorMessage>
</ValidationRule>
